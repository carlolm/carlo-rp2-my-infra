{
	acme_dns cloudflare {$CLOUDFLARE_API_TOKEN}
}

(gated) {
	forward_auth 127.0.0.1:4180 {
		uri /oauth2/auth
		copy_headers X-Auth-Request-User X-Auth-Request-Email
		@bad status 401
		handle_response @bad {
			redir https://auth.carlolm.com/oauth2/start?rd={scheme}://{host}{uri} 302
		}
	}
}

# Gatekeeper login endpoint (must stay unauthenticated for /oauth2/*)
auth.carlolm.com {
	reverse_proxy 127.0.0.1:4180
}

infra.carlolm.com {
	import gated
	reverse_proxy 127.0.0.1:7100
}

# Frontend + same-origin /api/* route to the API backend
nutrition.carlolm.com {
	import gated
	handle /api/* {
		reverse_proxy 127.0.0.1:7201
	}
	handle {
		reverse_proxy 127.0.0.1:7200
	}
}

# Direct API subdomain (kept for scripts/integrations)
api-nutrition.carlolm.com {
	import gated
	reverse_proxy 127.0.0.1:7201
}

news.carlolm.com {
	import gated
	reverse_proxy 127.0.0.1:7300
}
